```cpp
#include "http_server.hpp"
#include <thread>
#include <iostream>

void start_server() {
    std::thread([] {
        while (true) {
            std::cout << "[HTTP] alive..." << std::endl;
            std::this_thread::sleep_for(std::chrono::seconds(5));
        }
    }).detach();
}
```

