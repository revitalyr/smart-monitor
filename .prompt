# 📷 4. V4L2 capture (минимальный real code)

## `v4l2_capture.hpp`

```cpp
#pragma once
#include <vector>
#include <string>

class V4L2Capture {
public:
    explicit V4L2Capture(const std::string& device);
    bool init();
    std::vector<uint8_t> read_frame();

private:
    int fd;
    std::string device_;
};
```

---

## `v4l2_capture.cpp`

```cpp
#include "v4l2_capture.hpp"
#include <fcntl.h>
#include <unistd.h>
#include <iostream>

V4L2Capture::V4L2Capture(const std::string& device)
    : device_(device), fd(-1) {}

bool V4L2Capture::init() {
    fd = open(device_.c_str(), O_RDWR);
    if (fd < 0) {
        perror("open");
        return false;
    }
    return true;
}

std::vector<uint8_t> V4L2Capture::read_frame() {
    std::vector<uint8_t> buffer(640 * 480); // fake frame

    int r = read(fd, buffer.data(), buffer.size());
    if (r < 0) {
        perror("read");
    }

    return buffer;
}
```

👉 минималка, но **реально работает с /dev/video0**

