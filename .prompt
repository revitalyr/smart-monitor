# 🚀 6. main.cpp

```cpp
#include "video/v4l2_capture.hpp"
#include "ffi/rust_bridge.hpp"
#include "net/http_server.hpp"

#include <iostream>

int main() {
    V4L2Capture cam("/dev/video0");

    if (!cam.init()) {
        std::cerr << "Camera init failed\n";
        return 1;
    }

    start_server();

    auto prev = cam.read_frame();

    while (true) {
        auto curr = cam.read_frame();

        bool motion = detect_motion(
            prev.data(),
            curr.data(),
            curr.size(),
            20
        );

        if (motion) {
            std::cout << "Motion detected!\n";
        }

        prev = curr;
    }
}
```

